{
  "name": "maximus-fitness-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "postinstall": "npm run db:generate --workspace=@maximus/database"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.4",
    "typescript": "^5.4.5",
    "prisma": "^5.14.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "gsap": "^3.15.0",
    "zod": "^3.23.8",
    "@prisma/client": "^5.14.0"
  }
}
